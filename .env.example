# outreach-api-mcp configuration
#
# Copy to `.env` and fill in. Never commit `.env`.
#
# OAuth credentials come from an Outreach OAuth application you register in
# your own Outreach workspace (Settings → Integrations → API Access → "Create
# new app"). The first-time bootstrap script (`npm run bootstrap:oauth`) walks
# you through capturing the refresh token via a local browser consent flow.

# ─── Required ────────────────────────────────────────────────────────────────

# OAuth client ID from your Outreach OAuth app.
OUTREACH_CLIENT_ID=

# OAuth client secret from your Outreach OAuth app.
# Treat this as a high-sensitivity secret.
OUTREACH_CLIENT_SECRET=

# Long-lived refresh token captured by `npm run bootstrap:oauth`.
# After bootstrap, the MCP server rotates this on every refresh and persists
# the latest value to the on-disk token cache (default:
# `$XDG_CONFIG_HOME/outreach-api-mcp/token.json`, perms 0600).
# This env value is the initial seed; subsequent refreshes are read from cache.
OUTREACH_REFRESH_TOKEN=

# ─── Optional ────────────────────────────────────────────────────────────────

# Outreach API base. Defaults to the public US endpoint. Override only if
# Outreach support has assigned your workspace to a region-specific host.
# OUTREACH_API_BASE=https://api.outreach.io/api/v2

# Loopback port the bootstrap script binds while capturing the OAuth callback.
# Must match a redirect URI registered on the Outreach OAuth app, e.g.
#   http://127.0.0.1:8765/callback
# Defaults to 8765. Change here AND in the OAuth app config if you move it.
# OUTREACH_OAUTH_REDIRECT_PORT=8765

# Override the on-disk token cache path. Defaults to
# `$XDG_CONFIG_HOME/outreach-api-mcp/token.json` (or
# `~/.config/outreach-api-mcp/token.json`). Parent directory must be writable;
# file is created with 0600 perms.
# OUTREACH_TOKEN_CACHE_PATH=

# Logging verbosity (stderr only, never stdout). One of: debug, info, warn, error.
# Defaults to "info". Use "debug" sparingly — debug logs include request URLs.
# LOG_LEVEL=info
