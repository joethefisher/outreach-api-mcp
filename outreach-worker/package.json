{
  "name": "outreach-api-mcp",
  "version": "0.1.2",
  "description": "Independent MCP server for the Outreach v2 REST API — prospects, accounts, sequences, templates, snippets, tasks, mailings, audit logs.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "outreach",
    "outreach.io",
    "claude",
    "anthropic",
    "sales",
    "crm"
  ],
  "homepage": "https://github.com/joethefisher/outreach-api-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joethefisher/outreach-api-mcp.git",
    "directory": "outreach-worker"
  },
  "bugs": {
    "url": "https://github.com/joethefisher/outreach-api-mcp/issues"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "bin": {
    "outreach-api-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "npm run check && npm run lint && npm run format:check && npm run test && npm run build",
    "bootstrap:oauth": "tsx --env-file=../.env scripts/bootstrap-oauth.ts",
    "smoke:live": "tsx --env-file=../.env scripts/smoke-live.ts",
    "prepack": "cp ../README.md ./README.md && cp ../LICENSE ./LICENSE && npm run build",
    "postpack": "rm -f README.md LICENSE"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.4.1",
    "eslint-import-resolver-node": "0.3.9",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-security": "4.0.0",
    "prettier": "3.8.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.9"
  }
}
